# Published ports on Linux VM
NGINX_HTTP_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
CADVISOR_PORT=8080

# Optional image overrides (used by CI/CD deploy path)
BACKEND_IMAGE=supachat/backend:latest
MCP_IMAGE=supachat/backend:latest
FRONTEND_IMAGE=supachat/frontend:latest

# Grafana bootstrap credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# MCP request timeout used by backend
MCP_TIMEOUT_SECONDS=12
